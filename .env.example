# Supabase Credentials
# Copy this file to .env.local and fill in your project values.
# Never commit .env.local to version control.

# Found in: Supabase Dashboard → Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Found in: Supabase Dashboard → Settings → API → anon / public key
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: public URL for parent verification landing page.
# If unset, consent emails fall back to the verify-parental-consent function URL.
# Example: https://soma.health/parental-consent/verify
# EXPO_PUBLIC_PARENTAL_CONSENT_BASE_URL=

# ── Error tracking (Sentry) ─────────────────────────────────────────────────
# Optional. Found in: Sentry Dashboard → Settings → Projects → <project> → DSN
# Leave unset to disable Sentry in development.
# EXPO_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# ── Analytics (PostHog) ─────────────────────────────────────────────────────
# Optional. Found in: PostHog → Settings → Project → Project API key
# Leave unset to disable analytics in development.
# EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxxx

# ── Supabase Function Secrets Reference (set via `supabase secrets set`) ────
# These are NOT read from .env.local by the app directly.
# Keep a local copy in `supabase/.env.secrets.example` and configure in Supabase.
# DATA_RIGHTS_ADMIN_TOKEN=replace-with-long-random-token
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# PARENTAL_CONSENT_FROM_EMAIL=security@yourdomain.com
# PARENTAL_CONSENT_BASE_URL=https://yourdomain.com/parental-consent/verify
# FCM_PROJECT_ID=your-gcp-project-id
# SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
