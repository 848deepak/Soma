# Production environment variables for Expo app builds
# Do not commit real values in this file.

EXPO_PUBLIC_ENV=production
EXPO_PUBLIC_RELEASE_CHANNEL=production
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROD_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PROD_SUPABASE_ANON_KEY

# Do not point real-backend tests at production. Use a dedicated test project.
# SUPABASE_TEST_URL=https://YOUR_TEST_PROJECT_REF.supabase.co
# SUPABASE_TEST_ANON_KEY=YOUR_TEST_PROJECT_ANON_KEY

# Optional but recommended
# EXPO_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
# EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxxx
