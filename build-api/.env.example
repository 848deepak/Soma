# Environment Variables for Build API

# Server Configuration
PORT=3001

# GitHub Configuration (Required)
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# GitHub Token (Optional - increases API rate limits from 60/hr to 5000/hr)
# Create at: https://github.com/settings/tokens
# Permissions needed: "public_repo" (for public repos) or "repo" (for private repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS Configuration (Optional - defaults to localhost:3000)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
