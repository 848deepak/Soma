{
  "name": "womenproject",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "security:scan-secrets": "bash scripts/scan-secrets.sh",
    "security:verify-secrets": "bash scripts/verify-secrets.sh",
    "security:verify-secrets:production": "bash scripts/verify-secrets.sh production",
    "release:verify-config": "node scripts/verify-release-config.js",
    "release:dry-run": "bash scripts/release-dry-run.sh",
    "release:build-artifacts": "bash scripts/build-artifacts.sh",
    "e2e:ios": "detox build-framework-cache && detox test --configuration ios.sim.debug __tests__/e2e/smoke.e2e.ts",
    "e2e:ios:all": "detox test --configuration ios.sim.debug",
    "e2e:android": "detox test --configuration android.emu.debug",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "test:real-backend": "jest --config jest.real.config.js --runInBand",
    "test:real-auth": "jest --config jest.real.config.js __tests__/e2e/real-auth.e2e.test.ts --runInBand",
    "test:real-db": "jest --config jest.real.config.js __tests__/e2e/real-db.e2e.test.ts --runInBand"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-network": "~55.0.9",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-updates": "~55.0.15",
    "expo-web-browser": "~55.0.10",
    "nativewind": "^4.2.1",
    "posthog-react-native": "^4.37.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/detox": "^17.14.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.7.0",
    "detox": "^20.47.0",
    "eas-cli": "^18.4.0",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.11",
    "react-test-renderer": "^19.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true,
  "detox": {
    "testRunner": {
      "args": {
        "$0": "jest",
        "config": "__tests__/e2e/jest.config.js"
      },
      "jest": {
        "setupTimeout": 120000
      }
    },
    "apps": {
      "ios.debug": {
        "type": "ios.app",
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/Soma.app",
        "build": "xcodebuild -workspace ios/Soma.xcworkspace -scheme Soma -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build"
      },
      "android.debug": {
        "type": "android.apk",
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug"
      }
    },
    "devices": {
      "simulator": {
        "type": "ios.simulator",
        "device": {
          "type": "iPhone 17"
        }
      },
      "emulator": {
        "type": "android.emulator",
        "device": {
          "avdName": "Pixel_4_API_30"
        }
      }
    },
    "configurations": {
      "ios.sim.debug": {
        "device": "simulator",
        "app": "ios.debug"
      },
      "android.emu.debug": {
        "device": "emulator",
        "app": "android.debug"
      }
    }
  }
}
